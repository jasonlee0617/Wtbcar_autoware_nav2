<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro
    name="wvcsc_vehicle_base_macro"
    params="base_length base_width base_height base_link_to_footprint_z wheel_radius wheel_width wheel_x wheel_y"
  >
    <material name="white">
      <color rgba="1 1 1 1"/>
    </material>
    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>

    <link name="base_footprint">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.1 0.1 0.001"/>
        </geometry>
      </visual>
    </link>

    <joint name="base_link_joint" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="0 0 ${base_link_to_footprint_z}" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <xacro:macro name="wheel_macro" params="wheel_name x y">
      <joint name="${wheel_name}_joint" type="continuous">
        <origin xyz="${x} ${y} ${-base_height / 2.0}" rpy="1.57 0 0"/>
        <parent link="base_link"/>
        <child link="${wheel_name}_link"/>
        <axis xyz="0 1 0"/>
      </joint>

      <link name="${wheel_name}_link">
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
          </geometry>
          <material name="black"/>
        </visual>
      </link>
    </xacro:macro>

    <xacro:wheel_macro wheel_name="left_front" x="${wheel_x}" y="${wheel_y}"/>
    <xacro:wheel_macro wheel_name="right_front" x="${wheel_x}" y="${-wheel_y}"/>
    <xacro:wheel_macro wheel_name="left_wheel" x="${-wheel_x}" y="${wheel_y}"/>
    <xacro:wheel_macro wheel_name="right_wheel" x="${-wheel_x}" y="${-wheel_y}"/>
  </xacro:macro>
</robot>
