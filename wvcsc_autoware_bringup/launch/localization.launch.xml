<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_model" default="wvcsc_vehicle"/>
  <arg name="backend" default="autoware_ndt"/>
  <arg name="system_run_mode" default="online"/>
  <arg name="pose_source" default="ndt"/>
  <arg name="twist_source" default="gyro_odom"/>
  <arg name="input_pointcloud" default="/sensing/lidar/pointcloud_raw"/>
  <arg name="input_imu_topic" default="/sensing/imu/tamagawa/imu_raw"/>
  <arg name="autoware_imu_topic" default="/sensing/imu/imu_data"/>
  <arg name="relay_imu_to_autoware_topic" default="true"/>
  <arg name="launch_pointcloud_container" default="true"/>
  <arg name="localization_pointcloud_container_name" default="/localization_pointcloud_container"/>
  <arg name="loc_config_path" default="$(find-pkg-share wvcsc_autoware_bringup)/config/localization"/>
  <arg name="initial_pose" default="[]"/>
  <arg name="publish_identity_map_to_odom_tf" default="false"/>
  <arg name="ekf_param_file" default="$(find-pkg-share wtb_car_driver)/config/ekf_wtb_fdimu.yaml"/>

  <group if="$(eval &quot;'$(var backend)' == 'ekf'&quot;)">
    <node pkg="robot_localization" exec="ekf_node" name="ekf_filter_node" output="screen">
      <param from="$(var ekf_param_file)"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
      <remap from="/odometry/filtered" to="/ekf_odom"/>
    </node>

    <node pkg="topic_tools" exec="relay" name="ekf_odom_to_kinematic_state">
      <param name="input_topic" value="/ekf_odom"/>
      <param name="output_topic" value="/localization/kinematic_state"/>
    </node>

    <node if="$(var publish_identity_map_to_odom_tf)" pkg="tf2_ros" exec="static_transform_publisher" name="map_to_odom_identity_tf" args="0 0 0 0 0 0 map odom"/>
  </group>

  <group if="$(eval &quot;'$(var backend)' == 'autoware_ndt'&quot;)">
    <node if="$(var relay_imu_to_autoware_topic)" pkg="topic_tools" exec="relay" name="wvcsc_imu_to_autoware_imu_relay">
      <param name="input_topic" value="$(var input_imu_topic)"/>
      <param name="output_topic" value="$(var autoware_imu_topic)"/>
    </node>

    <include file="$(find-pkg-share autoware_launch)/launch/components/tier4_localization_component.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="vehicle_model" value="$(var vehicle_model)"/>
      <arg name="system_run_mode" value="$(var system_run_mode)"/>
      <arg name="pose_source" value="$(var pose_source)"/>
      <arg name="twist_source" value="$(var twist_source)"/>
      <arg name="input_pointcloud" value="$(var input_pointcloud)"/>
      <arg name="loc_config_path" value="$(var loc_config_path)"/>
      <arg name="initial_pose" value="$(var initial_pose)"/>
      <arg name="localization_pointcloud_container_name" value="$(var localization_pointcloud_container_name)"/>
      <arg name="launch_pointcloud_container" value="$(var launch_pointcloud_container)"/>
    </include>
  </group>
</launch>
