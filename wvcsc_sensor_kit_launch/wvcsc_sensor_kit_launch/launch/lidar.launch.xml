<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="vehicle_mirror_param_file" default="$(find-pkg-share wvcsc_vehicle_description)/config/mirror.param.yaml"/>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="launch_pointcloud_to_laserscan" default="true"/>
  <arg name="use_sim_time" default="false"/>

  <group>
    <push-ros-namespace namespace="lidar"/>

    <group if="$(var launch_driver)">
      <include file="$(find-pkg-share common_sensor_launch)/launch/lslidar_cx_launch.py"/>
    </group>

    <group if="$(var launch_pointcloud_to_laserscan)">
      <node pkg="pointcloud_to_laserscan" exec="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/sensing/lidar/pointcloud_raw"/>
        <remap from="scan" to="/sensing/lidar/scan"/>
        <param name="target_frame" value="laser"/>
        <param name="min_height" value="-0.75"/>
        <param name="max_height" value="0.50"/>
        <param name="angle_min" value="-3.1415926"/>
        <param name="angle_max" value="3.1415926"/>
        <param name="angle_increment" value="0.003"/>
        <param name="scan_time" value="0.3333"/>
        <param name="range_min" value="0.5"/>
        <param name="range_max" value="50.0"/>
        <param name="use_inf" value="true"/>
        <param name="inf_epsilon" value="50.0"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>
      </node>
    </group>
  </group>
</launch>
