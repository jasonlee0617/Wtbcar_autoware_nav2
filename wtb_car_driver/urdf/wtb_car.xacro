<?xml version="1.0" ?>
<robot name="wtb_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">


    <xacro:property name="base_length" value="1.30" /> 
    <xacro:property name="base_width"  value="0.80" /> 
    <xacro:property name="base_height" value="1.00" />  
    <xacro:property name="base_z"      value="0.16" />  

    <xacro:property name="wheel_radius" value="0.20" /> 
    <xacro:property name="wheel_length" value="0.12" />  
    <xacro:property name="wheel_z"      value="0" /> 

    <xacro:property name="wheel_x"      value="0.35" /> 
    

    <xacro:property name="lidar_radius"   value="0.08" /> 
    <xacro:property name="lidar_height"   value="0.15" />  
    <xacro:property name="lidar_x"        value="0.36" />     
    <xacro:property name="lidar_y"        value="0" />    
    <xacro:property name="lidar_z_offset" value="0.0" />   
    <xacro:property name="lidar_z" value="${base_height/2 +  lidar_z_offset}" />


    
    <xacro:property name="base_footprint_z" value="0.0" />  
    <xacro:property name="base_link_to_footprint_z" value="${base_z + base_height/2}" />  


    <xacro:macro name="material_white">
        <material name="white">
            <color rgba="1 1 1 1" />
        </material>
    </xacro:macro>

    <xacro:macro name="material_black">
        <material name="black">
            <color rgba="0 0 0 1" />
        </material>
    </xacro:macro>

    <xacro:macro name="material_gray">
        <material name="gray">
            <color rgba="0.5 0.5 0.5 1" />  
        </material>
    </xacro:macro>



    <xacro:macro name="base_footprint">
        <link name="base_footprint">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <box size="0.1 0.1 0.00" />  
                </geometry>
                <material name="red">
                    <color rgba="1 0 0 0.8" />  
                </material>
            </visual>
        </link>

         <joint name="base_link_joint" type="fixed">
            <parent link="base_footprint" />  
            <child link="base_link" />        
            <origin xyz="0 0 ${base_link_to_footprint_z}" rpy="0 0 0" />
        </joint>
    </xacro:macro>

    <xacro:macro name="base_link"> 
        <link name="base_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />  
                <geometry>
                    <box size="${base_length} ${base_width} ${base_height}" /> 
                </geometry>
                <xacro:material_white /> 
            </visual>
        </link>
    </xacro:macro>

    <xacro:macro name="wheel" params="wheel_name x y">

        <joint name="${wheel_name}_joint" type="continuous">
            <origin xyz="${x} ${y} ${-base_height/2 + wheel_z}" rpy="1.57 0 0" /> 
            <parent link="base_link" />
            <child link="${wheel_name}_link" />
            <axis xyz="0 1 0" /> 
        </joint>

 
        <link name="${wheel_name}_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" /> 
                </geometry>
                <xacro:material_black />  
            </visual>
        </link>
    </xacro:macro>


    <xacro:macro name="steer_wheel" params="wheel_name x y">
        <joint name="${wheel_name}_joint" type="revolute"> 
            <origin xyz="${x} ${y} ${wheel_z}" rpy="1.57 0 0" /> 
            <parent link="base_link" />
            <child link="${wheel_name}_link" />
            <axis xyz="0 0 1" /> 
            <limit 
                effort="100"       
                velocity="2.0"     
                lower="-0.6109"   
                upper="0.6109"    
            />
        </joint>

       
        <link name="${wheel_name}_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <xacro:material_black />
            </visual>
        </link>
    </xacro:macro>

    <xacro:macro name="lidar">
       
        <joint name="lidar_joint" type="fixed">  
            <parent link="base_link" />  
            <child link="laser" />
            <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 0" />
        </joint>


        <link name="laser">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />  
                <geometry>
                  
                    <cylinder radius="${lidar_radius}" length="${lidar_height}" />
                </geometry>
                <xacro:material_gray /> 
            </visual>
        </link>
    </xacro:macro>


    <xacro:macro name="imu">
       
        <joint name="IMU_joint" type="fixed">  
            <parent link="base_link" /> 
            <child link="gyro_link" />  
            <origin xyz="0 0 ${-base_height/2 +  0.1}" rpy="0 0 0"/> 
           
        </joint>


        <link name="gyro_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" /> 
                <geometry>
     
                    <box size="0.1 0.1 0.00" />  
                </geometry>
                <xacro:material_gray />  
            </visual>
        </link>
    </xacro:macro>


    <xacro:base_footprint /> 

    <xacro:base_link /> 
    <xacro:wheel wheel_name="left_front"    x="${wheel_x}"  y="0.43" />  
    <xacro:wheel wheel_name="right_wheel"   x="${-wheel_x}" y="-0.43" />
    <xacro:wheel wheel_name="left_wheel"    x="${-wheel_x}"  y="0.43" /> 
    <xacro:wheel wheel_name="right_front"   x="${wheel_x}"  y="-0.43" /> 

    <xacro:lidar /> 
    <xacro:imu /> 

</robot>
