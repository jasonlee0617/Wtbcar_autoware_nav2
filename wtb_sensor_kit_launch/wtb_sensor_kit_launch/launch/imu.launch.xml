<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="use_sim_time" default="false"/>

  <group if="$(var launch_driver)">
    <include file="$(find-pkg-share fdilink_ahrs)/launch/ahrs_driver_autoware.launch.py">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>

    <!-- Relay: /imu → /sensing/imu/imu_data
         fdilink_ahrs publishes to /imu (autoware_ahrs_params.yaml).
         Autoware gyro_odometer/EKF subscribe to /sensing/imu/imu_data. -->
    <node pkg="topic_tools" exec="relay" name="wtb_imu_to_autoware_relay">
      <param name="input_topic" value="/imu"/>
      <param name="output_topic" value="/sensing/imu/imu_data"/>
    </node>
  </group>
</launch>
