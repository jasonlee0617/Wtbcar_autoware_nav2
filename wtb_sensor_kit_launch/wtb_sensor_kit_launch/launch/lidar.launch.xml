<launch>
  <arg name="launch_driver" default="true"/>
  <arg name="vehicle_mirror_param_file" default="$(find-pkg-share wtb_vehicle_description)/config/mirror.param.yaml"/>
  <arg name="pointcloud_container_name" default="pointcloud_container"/>
  <arg name="launch_pointcloud_to_laserscan" default="true"/>
  <arg name="use_sim_time" default="false"/>

  <group>
    <push-ros-namespace namespace="lidar"/>

    <group if="$(var launch_driver)">
      <!-- OLD LSLiDAR driver path, kept as a rollback reference after RoboSense migration.
      <include file="$(find-pkg-share wtb_common_sensor_launch)/launch/lslidar_cx_launch.py"/> -->
      <include file="$(find-pkg-share rslidar_sdk)/launch/start.py"/>
    </group>

    <group if="$(var launch_pointcloud_to_laserscan)">
      <node pkg="pointcloud_to_laserscan" exec="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/sensing/lidar/pointcloud_raw"/>
        <remap from="scan" to="/sensing/lidar/scan"/>
        <param name="target_frame" value="laser"/>
        <param name="min_height" value="-1.6"/>
        <param name="max_height" value="0.50"/>
        <param name="transform_tolerance" value="1.0"/>
        <param name="angle_min" value="-3.1415926"/>
        <param name="angle_max" value="3.1415926"/>
        <param name="angle_increment" value="0.0003"/>
        <param name="scan_time" value="0.3333"/>
        <param name="range_min" value="0.5"/>
        <param name="range_max" value="50.0"/>
        <param name="use_inf" value="true"/>
        <param name="inf_epsilon" value="50.0"/>
        <param name="use_sim_time" value="$(var use_sim_time)"/>
      </node>
    </group>

    <!-- OLD: PointXYZIRT → PointXYZIRC format adapter (replaced by point_cloud_transformer)
    <node pkg="wtb_common_sensor_launch" exec="pointcloud_xyzirt_to_xyzirc"
          name="wtb_pointcloud_autoware_adapter" output="screen">
      <param name="input_topic" value="/sensing/lidar/pointcloud_raw"/>
      <param name="output_topic" value="/sensing/lidar/concatenated/pointcloud"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node> -->
   

    <!-- PointCloud transformer: laser -> base_link TF + XYZIRC format. -->
    <node pkg="wtb_common_sensor_launch" exec="point_cloud_transformer"
          name="wtb_pointcloud_transformer" output="screen">
      <param name="use_height_filter" value="false"/>
      <param name="input_topic" value="/sensing/lidar/pointcloud_raw"/>
      <param name="output_topic" value="/sensing/lidar/concatenated/pointcloud"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

    <!-- Remove only near-center ego reflections before obstacle segmentation and obstacle_stop use the cloud. -->
    <!-- <node pkg="autoware_pointcloud_preprocessor" exec="crop_box_filter_node"
          name="wtb_self_crop_box_filter" output="screen">
      <remap from="input" to="/sensing/lidar/transformed/pointcloud"/>
      <remap from="output" to="/sensing/lidar/concatenated/pointcloud"/>
      <param name="input_frame" value="base_link"/>
      <param name="output_frame" value="base_link"/>
      <param name="negative" value="true"/>
      <param name="min_x" value="-0.85"/>
      <param name="max_x" value="0.55"/>
      <param name="min_y" value="-0.50"/>
      <param name="max_y" value="0.50"/>
      <param name="min_z" value="0.55"/>
      <param name="max_z" value="1.20"/>
      <param name="processing_time_threshold_sec" value="0.01"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node> -->
  </group>
</launch>
