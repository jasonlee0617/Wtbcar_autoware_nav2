<?xml version="1.0"?>
<robot name="wtb_vehicle" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:arg name="vehicle_model" default="wtb_vehicle"/>
  <xacro:arg name="sensor_model" default="wtb_sensor_kit"/>
  <xacro:arg name="config_dir" default="$(find wtb_sensor_kit_description)/config"/>

  <!-- Keep the previous full-vehicle behavior in one vehicle description file. -->
  <xacro:property name="vehicle_info" value="${xacro.load_yaml('$(find wtb_vehicle_description)/config/vehicle_info.param.yaml')}"/>
  <xacro:property name="vehicle_params" value="${vehicle_info['/**']['ros__parameters']}"/>
  <xacro:property name="base_width" value="0.80"/>
  <!-- Autoware: base_link should be on the ground at the rear axle center.
       This value is now the body/sensor-kit center height above base_link. -->
  <xacro:property name="base_link_to_body_center_z" value="0.66"/>

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <link name="base_footprint">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="${vehicle_params['wheel_base'] / 2.0} 0 ${base_link_to_body_center_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${vehicle_params['vehicle_length']} ${base_width} ${vehicle_params['vehicle_height']}"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <xacro:macro name="wtb_wheel_macro" params="wheel_name x y">
    <joint name="${wheel_name}_joint" type="continuous">
      <origin xyz="${x} ${y} ${vehicle_params['wheel_radius']}" rpy="1.57 0 0"/>
      <parent link="base_link"/>
      <child link="${wheel_name}_link"/>
      <axis xyz="0 1 0"/>
    </joint>

    <link name="${wheel_name}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${vehicle_params['wheel_radius']}" length="${vehicle_params['wheel_width']}"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>
  </xacro:macro>

  <xacro:wtb_wheel_macro
    wheel_name="left_front"
    x="${vehicle_params['wheel_base']}"
    y="${vehicle_params['wheel_tread'] / 2.0}"
  />
  <xacro:wtb_wheel_macro
    wheel_name="right_front"
    x="${vehicle_params['wheel_base']}"
    y="${-vehicle_params['wheel_tread'] / 2.0}"
  />
  <xacro:wtb_wheel_macro
    wheel_name="left_wheel"
    x="0.0"
    y="${vehicle_params['wheel_tread'] / 2.0}"
  />
  <xacro:wtb_wheel_macro
    wheel_name="right_wheel"
    x="0.0"
    y="${-vehicle_params['wheel_tread'] / 2.0}"
  />

</robot>
