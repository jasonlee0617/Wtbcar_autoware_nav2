<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_model" default="wtb_vehicle"/>
  <arg name="sensor_model" default="wtb_sensor_kit"/>
  <arg name="config_dir" default="$(find-pkg-share $(var sensor_model)_description)/config"/>
  <arg name="launch_joint_state_publisher" default="true"/>

  <set_parameter name="use_sim_time" value="$(var use_sim_time)"/>

  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
    <param
      name="robot_description"
      value="$(command 'xacro $(find-pkg-share tier4_vehicle_launch)/urdf/vehicle.xacro vehicle_model:=$(var vehicle_model) sensor_model:=$(var sensor_model) config_dir:=$(var config_dir)' 'warn')"
    />
  </node>

  <!-- Wheel joints are continuous joints. robot_state_publisher publishes
       fixed joints on /tf_static, but it needs /joint_states to publish the
       four wheel link transforms. This matches the validated wtb_car startup
       chain and keeps the wheel TFs available for RViz RobotModel. -->
  <node if="$(var launch_joint_state_publisher)"
        pkg="joint_state_publisher"
        exec="joint_state_publisher"
        name="joint_state_publisher">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>
</launch>
