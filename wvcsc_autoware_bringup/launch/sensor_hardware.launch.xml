<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- ================================================================
       WVCSC 传感器硬件层
       负责：LiDAR 驱动 + IMU 驱动 + pointcloud_to_laserscan（可选）
       不负责：CAN / 底盘驱动（见 vehicle_hardware.launch.xml）
       ================================================================ -->
  <arg name="use_sim_time" default="false"/>
  <arg name="launch_driver" default="true"/>
  <arg name="sensor_model" default="wvcsc_sensor_kit"/>
  <arg name="launch_pointcloud_to_laserscan" default="false"/>

  <!-- ================================================================
       sensing.launch.xml 包含：
       - LiDAR 驱动 (lslidar_cx)
       - IMU 驱动 (fdilink_ahrs)
       - pointcloud_to_laserscan (可选)
       - vehicle_velocity_converter
       ================================================================ -->
  <include file="$(find-pkg-share wvcsc_sensor_kit_launch)/launch/sensing.launch.xml">
    <arg name="launch_driver" value="$(var launch_driver)"/>
    <arg name="launch_pointcloud_to_laserscan" value="$(var launch_pointcloud_to_laserscan)"/>
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
  </include>
</launch>
