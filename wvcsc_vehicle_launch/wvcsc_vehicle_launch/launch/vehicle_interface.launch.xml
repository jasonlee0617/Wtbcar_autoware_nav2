<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>
  <arg name="raw_vehicle_cmd_converter_param_path" default=""/>
  <arg name="initial_engage_state" default="false"/>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_interface_param_path" default="$(find-pkg-share wvcsc_vehicle_interface)/config/vehicle_interface_params.yaml"/>

  <node pkg="wvcsc_vehicle_interface" exec="vehicle_interface_node" name="wvcsc_vehicle_interface" output="screen">
    <param from="$(var vehicle_interface_param_path)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>
</launch>
