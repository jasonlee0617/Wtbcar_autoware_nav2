<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_model" default="wtb_vehicle"/>
  <arg name="sensor_model" default="wtb_sensor_kit"/>
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>

  <arg name="wheelbase" default="0.82"/>
  <arg name="vel_scale" default="1.0"/>
  <arg name="steer_offset" default="0.0"/>
  <arg name="min_speed" default="0.0005"/>
  <arg name="max_speed" default="1.0"/>

  <arg name="launch_ekf" default="false"/>
  <arg name="relay_imu_to_ekf_topic" default="true"/>
  <arg name="input_imu_topic" default="/imu"/>
  <arg name="ekf_imu_topic" default="/imu"/>
  <arg name="ekf_param_file" default="$(find-pkg-share wtb_vehicle_launch)/config/ekf_wtb_fdimu.yaml"/>

  <include file="$(find-pkg-share wtb_vehicle_launch)/launch/vehicle.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="vehicle_model" value="$(var vehicle_model)"/>
    <arg name="sensor_model" value="$(var sensor_model)"/>
  </include>

  <include file="$(find-pkg-share can_bridge)/launch/can_bridge.launch.py"/>

  <node pkg="wtb_car_driver" exec="wtb_car" name="wtb_car" output="screen">
    <param name="WHEELBASE" value="$(var wheelbase)"/>
    <param name="vel_scale" value="$(var vel_scale)"/>
    <param name="steer_offset" value="$(var steer_offset)"/>
    <param name="min_speed" value="$(var min_speed)"/>
    <param name="max_speed" value="$(var max_speed)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node if="$(var relay_imu_to_ekf_topic)" pkg="topic_tools" exec="relay"
        name="wtb_imu_to_ekf_imu_relay">
    <param name="input_topic" value="$(var input_imu_topic)"/>
    <param name="output_topic" value="$(var ekf_imu_topic)"/>
  </node>

  <node if="$(var launch_ekf)" pkg="robot_localization" exec="ekf_node"
        name="ekf_filter_node" output="screen">
    <param from="$(var ekf_param_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="/odometry/filtered" to="/ekf_odom"/>
  </node>

  <include file="$(find-pkg-share wtb_vehicle_launch)/launch/vehicle_interface.launch.xml">
    <arg name="vehicle_id" value="$(var vehicle_id)"/>
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="launch_vehicle_hardware" value="false"/>
  </include>
</launch>
