<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <arg name="map_path" description="point cloud and lanelet2 map directory path"/>
  <arg name="vehicle_model" default="wvcsc_vehicle"/>
  <arg name="sensor_model" default="wvcsc_sensor_kit"/>
  <arg name="data_path" default="$(env HOME)/autoware_data/ml_models"/>
  <arg name="planning_module_preset" default="default"/>
  <arg name="control_module_preset" default="default"/>
  <arg name="lanelet2_map_file" default="lanelet2_map.osm"/>
  <arg name="pointcloud_map_file" default="pointcloud_map.pcd"/>
  <arg name="launch_perception" default="false"/>
  <arg name="launch_system_monitor" default="false"/>
  <arg name="launch_dummy_diag_publisher" default="false"/>
  <arg name="rviz" default="true"/>
  <arg name="rviz_config_name" default="autoware.rviz"/>
  <arg name="use_sim_time" default="false"/>
  <arg name="vehicle_id" default="$(env VEHICLE_ID default)"/>

  <include file="$(find-pkg-share autoware_launch)/launch/autoware.launch.xml">
    <arg name="map_path" value="$(var map_path)"/>
    <arg name="vehicle_model" value="$(var vehicle_model)"/>
    <arg name="sensor_model" value="$(var sensor_model)"/>
    <arg name="data_path" value="$(var data_path)"/>
    <arg name="planning_module_preset" value="$(var planning_module_preset)"/>
    <arg name="control_module_preset" value="$(var control_module_preset)"/>
    <arg name="lanelet2_map_file" value="$(var lanelet2_map_file)"/>
    <arg name="pointcloud_map_file" value="$(var pointcloud_map_file)"/>
    <arg name="launch_vehicle" value="false"/>
    <arg name="launch_system" value="true"/>
    <arg name="launch_map" value="true"/>
    <arg name="launch_sensing" value="false"/>
    <arg name="launch_localization" value="false"/>
    <arg name="launch_perception" value="$(var launch_perception)"/>
    <arg name="launch_planning" value="true"/>
    <arg name="launch_control" value="true"/>
    <arg name="launch_api" value="true"/>
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="vehicle_id" value="$(var vehicle_id)"/>
    <arg name="launch_system_monitor" value="$(var launch_system_monitor)"/>
    <arg name="launch_dummy_diag_publisher" value="$(var launch_dummy_diag_publisher)"/>
    <arg name="rviz" value="$(var rviz)"/>
    <arg name="rviz_config_name" value="$(var rviz_config_name)"/>
    <arg name="is_simulation" value="false"/>
  </include>
</launch>
